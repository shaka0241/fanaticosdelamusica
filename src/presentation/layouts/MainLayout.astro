---
import '../../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Fanáticos de la Música, el programa de radio que te hace recordar y bailar con los mejores ritmos." } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Favicon and PWA -->
		<link rel="icon" type="image/jpeg" href="/logo.jpeg" />
		<link rel="apple-touch-icon" href="/icon-192x192.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#d25d11" />
		
		<!-- iOS Safari PWA tags -->
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="apple-mobile-web-app-title" content="Fanáticos">
		
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title} | Fanáticos de la Música</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- Service Worker Registration -->
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').catch((error) => {
						console.error('ServiceWorker registration failed: ', error);
					});
				});
			}
		</script>
	</head>
	<body class="bg-brand-light text-brand-text font-sans antialiased selection:bg-brand-primary selection:text-white flex flex-col min-h-screen">
		<slot />
	</body>
</html>
