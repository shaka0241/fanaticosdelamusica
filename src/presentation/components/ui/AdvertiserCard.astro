---
import type { Advertiser } from '../../../domain/types';

interface Props {
    advertiser: Advertiser;
}

const { advertiser } = Astro.props;
---

<div class="bg-brand-light border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:border-brand-primary/30 transition-all duration-300 group flex flex-col h-full transform hover:-translate-y-1">
    
    <div class="w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-5 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
    </div>

    <h3 class="text-xl font-bold text-brand-dark mb-3 leading-snug group-hover:text-brand-primary line-clamp-2">{advertiser.name}</h3>
    <p class="text-gray-600 text-sm flex-grow mb-6 line-clamp-3">{advertiser.desc}</p>
    
    <div class="mt-auto pt-4 border-t border-gray-200/60">
        {advertiser.phone ? (
            <a href={`tel:${advertiser.phone.replace(/\D/g, '')}`} class="inline-flex items-center text-sm font-semibold text-brand-secondary hover:text-brand-primary transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                {advertiser.phone}
            </a>
        ) : (
            <span class="inline-flex items-center text-sm font-medium text-gray-400">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                Visítanos
            </span>
        )}
    </div>
</div>
