---
import type { Advertiser } from '../../../domain/types';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
    advertiser: Advertiser;
}

const { advertiser } = Astro.props;

// Load images from assets dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/sponsors/*.{jpeg,jpg,png,svg,webp}');
const imagePath = advertiser.image ? `/src/assets/sponsors/${advertiser.image}` : null;
let imageData = null;

if (imagePath && images[imagePath]) {
    const mod = await images[imagePath]();
    imageData = mod.default;
}
---

<div class="bg-brand-light border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:border-brand-primary/30 transition-all duration-300 group flex flex-col h-full transform hover:-translate-y-1">
    
    {imageData ? (
        <div class="w-full h-40 mb-5 rounded-xl overflow-hidden shadow-sm flex items-center justify-center">
           {advertiser.image?.endsWith('.svg') ? (
               <img src={imageData.src} alt={advertiser.name} class="w-full h-full object-cover" />
           ) : (
               <div class="w-full h-full bg-white flex items-center justify-center p-3 border border-gray-100/50 rounded-xl">
                   <Image src={imageData} alt={advertiser.name} class="w-full h-full object-contain" />
               </div>
           )}
        </div>
    ) : (
        <div class="w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-5 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300">
            <Icon name="tabler:building-store" class="w-6 h-6" />
        </div>
    )}

    <h3 class="text-xl font-bold text-brand-dark mb-3 leading-snug group-hover:text-brand-primary line-clamp-2">{advertiser.name}</h3>
    <p class="text-gray-600 text-sm flex-grow mb-6 line-clamp-3">{advertiser.desc}</p>
    
    <div class="mt-auto pt-4 border-t border-gray-200/60 flex flex-col gap-2">
        {advertiser.schedule && (
            <div class="flex items-start text-xs text-gray-500">
                <Icon name="tabler:clock" class="w-4 h-4 mr-2 flex-shrink-0 mt-0.5" />
                <span>{advertiser.schedule}</span>
            </div>
        )}
        
        {advertiser.address && (
            <div class="flex items-start text-xs text-gray-500">
                <Icon name="tabler:map-pin" class="w-4 h-4 mr-2 flex-shrink-0 mt-0.5" />
                <span>{advertiser.address}</span>
            </div>
        )}
        
        {advertiser.social && (
            <div class="flex items-start text-xs text-gray-500">
                <Icon name="tabler:brand-instagram" class="w-4 h-4 mr-2 flex-shrink-0 mt-0.5" />
                <span>{advertiser.social}</span>
            </div>
        )}

        <div class="flex flex-wrap gap-x-4 gap-y-2 mt-2 items-center">
            {advertiser.whatsapp && (
                <a href={`https://wa.me/58${advertiser.whatsapp.replace(/\D/g, '').replace(/^0+/, '')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-semibold text-[#25D366] hover:text-green-600 transition-colors">
                    <Icon name="tabler:brand-whatsapp" class="w-5 h-5 mr-1" />
                    WhatsApp
                </a>
            )}
            
            {advertiser.phone && (
                <a href={`tel:${advertiser.phone.replace(/\D/g, '')}`} class="inline-flex items-center text-sm font-semibold text-brand-secondary hover:text-brand-primary transition-colors">
                    <Icon name="tabler:phone" class="w-4 h-4 mr-1.5" />
                    Llamar
                </a>
            )}
            
            {(!advertiser.whatsapp && !advertiser.phone) && (
                <span class="inline-flex items-center text-sm font-medium text-gray-400">
                    <Icon name="tabler:map-pin" class="w-4 h-4 mr-1.5" />
                    Visítanos
                </span>
            )}
        </div>
    </div>
</div>
