---
import type { Advertiser } from '../../../domain/types';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { calcularIsOpen } from '../../../utils/scheduleUtils';

interface Props {
    advertiser: Advertiser;
}

const { advertiser } = Astro.props;

// Si hay horario definido, calcular el estado en tiempo real (zona horaria: América/Caracas)
// Si no hay horario, usar el valor estático isOpen (o undefined si tampoco existe)
const isOpen = advertiser.schedule
    ? calcularIsOpen(advertiser.schedule)
    : advertiser.isOpen;

// Load images from assets dynamically
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/sponsors/*.{jpeg,jpg,png,svg,webp}');
const imagePath = advertiser.image ? `/src/assets/sponsors/${advertiser.image}` : null;
let imageData = null;

if (imagePath && images[imagePath]) {
    const mod = await images[imagePath]();
    imageData = mod.default;
}
---

<div class="bg-brand-light border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:border-brand-primary/30 transition-all duration-300 group flex flex-col h-full transform hover:-translate-y-1">
    
    {imageData ? (
        <div class="w-full h-40 mb-5 rounded-xl overflow-hidden shadow-sm flex items-center justify-center relative">
           {isOpen !== undefined && isOpen !== null && (
               <div class={`absolute top-3 left-3 z-10 px-2 py-1 rounded-full text-xs font-bold shadow-md flex items-center gap-1.5 ${isOpen ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                   <span class={`w-2 h-2 rounded-full ${isOpen ? 'bg-green-500' : 'bg-red-500'}`}></span>
                   {isOpen ? 'Abierto' : 'Cerrado'}
               </div>
           )}
           {advertiser.image?.endsWith('.svg') ? (
               <img src={imageData.src} alt={advertiser.altText || advertiser.name} class="w-full h-full object-cover" />
           ) : (
               <div class="w-full h-full bg-white flex items-center justify-center p-3 border border-gray-100/50 rounded-xl relative">
                   <Image src={imageData} alt={advertiser.altText || advertiser.name} class="w-full h-full object-contain" />
               </div>
           )}
        </div>
    ) : (
        <div class="w-12 h-12 rounded-xl bg-brand-primary/10 text-brand-primary flex items-center justify-center mb-5 group-hover:bg-brand-primary group-hover:text-white transition-colors duration-300 relative">
            {isOpen !== undefined && isOpen !== null && (
                <span class={`absolute -top-1 -right-1 w-3 h-3 rounded-full border-2 border-white ${isOpen ? 'bg-green-500' : 'bg-red-500'}`}></span>
            )}
            <Icon name="tabler:building-store" class="w-6 h-6" />
        </div>
    )}

    {advertiser.tags && advertiser.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-3">
            {advertiser.tags.map(tag => (
                <span class="px-2 py-0.5 bg-brand-primary/10 text-brand-primary text-[11px] uppercase tracking-wide font-bold rounded-md border border-brand-primary/20">{tag}</span>
            ))}
        </div>
    )}

    <h3 class="text-xl font-bold text-brand-dark mb-3 leading-snug group-hover:text-brand-primary line-clamp-2">{advertiser.name}</h3>
    <p class="text-gray-600 text-sm flex-grow mb-6 line-clamp-3">{advertiser.desc}</p>
    
    <div class="mt-auto pt-4 border-t border-gray-200/60 flex flex-col gap-3">
        {advertiser.schedule && (
            <div class="flex items-start text-xs text-gray-500 font-medium">
                <Icon name="tabler:clock" class="w-4 h-4 mr-2 flex-shrink-0 mt-0.5" />
                <span>{advertiser.schedule}</span>
            </div>
        )}
        
        {advertiser.address && (
            <div class="flex items-start text-xs text-gray-500 font-medium">
                <Icon name="tabler:map-pin" class="w-4 h-4 mr-2 flex-shrink-0 mt-0.5" />
                <span>{advertiser.address}</span>
            </div>
        )}
        
        <div class="flex flex-wrap gap-2 mt-2 pt-3 border-t border-gray-100/60 justify-between items-center -mx-2 px-2 pb-1 rounded-lg">
            
            <div class="flex gap-2">
                {advertiser.instagram && (
                    <a href={`https://instagram.com/${advertiser.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-pink-50 text-pink-600 flex items-center justify-center hover:bg-pink-600 hover:text-white transition-colors" aria-label={`Instagram de ${advertiser.name}`}>
                        <Icon name="tabler:brand-instagram" class="w-5 h-5" />
                    </a>
                )}
                {advertiser.facebook && (
                    <a href={advertiser.facebook.includes('http') ? advertiser.facebook : `https://facebook.com/${advertiser.facebook}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center hover:bg-blue-600 hover:text-white transition-colors" aria-label={`Facebook de ${advertiser.name}`}>
                        <Icon name="tabler:brand-facebook" class="w-5 h-5" />
                    </a>
                )}
                {advertiser.tiktok && (
                    <a href={`https://tiktok.com/${advertiser.tiktok.startsWith('@') ? advertiser.tiktok : '@' + advertiser.tiktok}`} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-slate-100 text-slate-700 flex items-center justify-center hover:bg-slate-800 hover:text-white transition-colors" aria-label={`TikTok de ${advertiser.name}`}>
                        <Icon name="tabler:brand-tiktok" class="w-5 h-5" />
                    </a>
                )}
            </div>

            <div class="flex gap-2">
                {advertiser.mapsUrl && (
                    <a href={advertiser.mapsUrl} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-amber-50 text-amber-600 flex items-center justify-center hover:bg-amber-500 hover:text-white transition-colors" aria-label="Ver en Google Maps">
                        <Icon name="tabler:map-pin" class="w-5 h-5" />
                    </a>
                )}
                {advertiser.phone && (
                    <a href={`tel:${advertiser.phone.replace(/\D/g, '')}`} class="w-10 h-10 rounded-full bg-gray-100 text-gray-600 flex items-center justify-center hover:bg-brand-primary hover:text-white transition-colors" aria-label="Llamar">
                        <Icon name="tabler:phone" class="w-5 h-5" />
                    </a>
                )}
                {advertiser.whatsapp && (
                    <a href={`https://wa.me/58${advertiser.whatsapp.replace(/\D/g, '').replace(/^0+/, '')}`} target="_blank" rel="noopener noreferrer" class="h-10 px-4 rounded-full bg-[#25D366]/10 text-[#25D366] flex items-center justify-center hover:bg-[#25D366] hover:text-white transition-colors text-sm font-bold gap-1.5" aria-label="WhatsApp">
                        <Icon name="tabler:brand-whatsapp" class="w-5 h-5" />
                        Chat
                    </a>
                )}
            </div>

        </div>
    </div>
</div>
