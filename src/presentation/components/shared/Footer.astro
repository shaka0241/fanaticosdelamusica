---
---

<footer class="bg-brand-dark text-white pt-16 pb-8 border-t-8 border-brand-primary">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
            
            <!-- Marca y Descripción -->
            <div class="md:col-span-1">
                <a href="#" class="flex items-center gap-3 mb-6">
                    <img class="h-14 w-auto rounded-full border-2 border-brand-primary/50" src="/logo.jpeg" alt="Fanáticos de la Música Logo">
                    <div>
                        <span class="block text-white font-bold text-xl tracking-tight leading-none mb-1">Fanáticos de</span>
                        <span class="block text-brand-primary font-bold text-xl tracking-tight leading-none">la Música</span>
                    </div>
                </a>
                <p class="text-gray-400 text-sm leading-relaxed mb-6">
                    El programa que trae jocosidad, buena vibra y los mejores recuerdos musicales. Conectando generaciones a través de la gaita, la salsa y los ritmos tropicales.
                </p>
                <!-- Redes Sociales Simuladas -->
                <div class="flex space-x-4">
                    <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-gray-400 hover:bg-brand-primary hover:text-white transition-all transform hover:-translate-y-1">
                        <span class="sr-only">Facebook</span>
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
                    </a>
                    <a href="#" class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-gray-400 hover:bg-brand-secondary hover:text-white transition-all transform hover:-translate-y-1">
                        <span class="sr-only">Instagram</span>
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" /></svg>
                    </a>
                </div>
            </div>

            <!-- Enlaces Rápidos -->
            <div class="md:col-span-1 md:pl-12">
                <h4 class="text-white font-bold text-lg mb-6 flex items-center">
                    <span class="w-8 h-1 bg-brand-primary mr-3 rounded"></span>
                    Navegación
                </h4>
                <ul class="space-y-3">
                    <li><a href="#inicio" class="text-gray-400 hover:text-brand-primary transition-colors flex items-center"><svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg> Inicio</a></li>
                    <li><a href="#nosotros" class="text-gray-400 hover:text-brand-primary transition-colors flex items-center"><svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg> Sobre el Programa</a></li>
                    <li><a href="#anunciantes" class="text-gray-400 hover:text-brand-primary transition-colors flex items-center"><svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg> Anunciantes</a></li>
                    <li><a href="#contacto" class="text-gray-400 hover:text-brand-primary transition-colors flex items-center"><svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg> Publicidad</a></li>
                </ul>
            </div>

            <!-- Horarios -->
            <div class="md:col-span-1">
                <h4 class="text-white font-bold text-lg mb-6 flex items-center">
                    <span class="w-8 h-1 bg-brand-accent-yellow mr-3 rounded"></span>
                    Sintonízanos
                </h4>
                <div class="bg-white/5 rounded-xl p-5 border border-white/10">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 rounded-full bg-brand-secondary/20 text-brand-secondary flex items-center justify-center">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <p class="text-white font-semibold">Fines de Semana</p>
                            <p class="text-brand-secondary text-sm">Próximamente Horarios</p>
                        </div>
                    </div>
                    <div class="text-gray-400 text-sm italic">
                        "Transmisión en vivo por Misión 94.3 FM y plataformas digitales"
                    </div>
                </div>
            </div>
            
        </div>

        <!-- Copyright -->
        <div class="border-t border-white/10 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500">
            <p>&copy; {new Date().getFullYear()} Fanáticos de la Música. Todos los derechos reservados.</p>
            <p class="mt-2 md:mt-0 flex items-center">
                Hecho con <svg class="w-4 h-4 text-brand-accent-red mx-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg> en Cabimas por <span class="text-white font-medium ml-1">Alberto Rojas</span>
            </p>
        </div>
    </div>
</footer>
