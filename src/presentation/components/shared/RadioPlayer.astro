---
// Componente de reproductor de radio funcional con el stream de fanatiocos de la musica.
---

<section id="reproductor" class="py-12 bg-brand-dark text-white relative border-y-4 border-brand-primary">
    <!-- Decoración de frecuencias de radio en el fondo -->
    <div class="absolute inset-0 opacity-10 pointer-events-none flex items-center justify-center overflow-hidden">
        <svg class="w-[200%] h-32 text-brand-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 100" preserveAspectRatio="none">
            <path stroke="currentColor" stroke-width="2" fill="none" d="M0,50 Q25,0 50,50 T100,50 T150,50 T200,50 T250,50 T300,50 T350,50 T400,50 T450,50 T500,50 T550,50 T600,50 T650,50 T700,50 T750,50 T800,50 T850,50 T900,50 T950,50 T1000,50"/>
        </svg>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-8 bg-black/40 backdrop-blur-md rounded-3xl p-6 md:p-8 border border-white/10 shadow-2xl">
            
            <div class="flex items-center gap-6">
                <!-- Icono animado de disco -->
                <div id="spin-disc" class="relative w-20 h-20 flex-shrink-0 animate-none">
                    <div class="absolute inset-0 rounded-full border-4 border-brand-primary bg-[#111] shadow-[0_0_15px_rgba(210,93,17,0.5)]"></div>
                    <div class="absolute inset-2 rounded-full border border-gray-700"></div>
                    <div class="absolute inset-4 rounded-full border border-gray-600"></div>
                    <div class="absolute inset-0 m-auto w-6 h-6 rounded-full bg-brand-accent-red"></div>
                    <div class="absolute inset-0 m-auto w-2 h-2 rounded-full bg-white z-10"></div>
                </div>
                
                <div>
                    <div class="flex items-center gap-2 mb-1">
                        <span class="relative flex h-3 w-3">
                          <span id="al-aire-ping" class="absolute inline-flex h-full w-full rounded-full bg-brand-accent-red opacity-75 hidden"></span>
                          <span class="relative inline-flex rounded-full h-3 w-3 bg-brand-accent-red"></span>
                        </span>
                        <span class="text-brand-accent-red font-bold text-sm uppercase tracking-wider">Al Aire</span>
                    </div>
                    <h3 class="text-2xl font-bold">Transmitiendo en Vivo</h3>
                    <p id="show-title" class="text-gray-400 text-sm font-medium transition-opacity duration-500">Misión 94.3 FM - Programación Regular</p>
                </div>
            </div>

            <!-- Controles del Reproductor (Funcional) -->
            <div class="flex-grow max-w-xl w-full">
                <div class="bg-black/80 rounded-full p-2 pr-6 flex items-center justify-between border border-white/10">
                    <button id="play-btn" class="flex-shrink-0 w-14 h-14 rounded-full bg-brand-secondary text-white flex items-center justify-center hover:bg-brand-secondary/80 transition shadow-[0_0_15px_rgba(39,156,216,0.5)] hover:scale-105">
                        <svg id="icon-play" class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                        <svg id="icon-pause" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
                    </button>
                    
                    <div class="flex-grow mx-4 relative hidden sm:block">
                        <div class="h-1 bg-gray-800 rounded-full overflow-hidden">
                            <div id="player-progress" class="h-full bg-brand-primary w-full origin-left transition-all duration-300 transform scale-x-0"></div>
                        </div>
                    </div>

                    <!-- Controles de Volumen -->
                    <div class="flex gap-3 items-center ml-2 hidden sm:flex">
                        <button id="btn-mute" class="text-gray-400 hover:text-white transition-colors" aria-label="Silenciar">
                            <svg id="icon-vol-up" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path></svg>
                            <svg id="icon-vol-mute" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" clip-rule="evenodd"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg>
                        </button>
                        <input type="range" id="volume-slider" min="0" max="1" step="0.01" value="1" class="w-20 sm:w-24 h-1.5 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-brand-secondary">
                    </div>
                </div>
                <!-- Control de volumen mobile -->
                <div class="flex items-center justify-center mt-4 sm:hidden gap-3 px-4">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path></svg>
                    <input type="range" id="volume-slider-mobile" min="0" max="1" step="0.01" value="1" class="w-full h-1.5 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-brand-secondary">
                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"></path></svg>
                </div>
                
                <p id="player-status" class="text-xs text-center mt-3 text-gray-500">Haz clic en Play para escuchar la transmisión en vivo.</p>

                <audio id="radio-audio" preload="none">
                    <source src="https://stream.zeno.fm/unsxrfcdn5jtv" type="audio/mpeg">
                </audio>
            </div>
            
        </div>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // --- Constantes de Horario ---
        const SHOW_START_HOUR = 8;
        const SHOW_END_HOUR = 12; // Exclusive
        const SUNDAY_DAY_INDEX = 0;
        const SATURDAY_DAY_INDEX = 6;
        
        // --- Referencias UI ---
        const playBtn = document.getElementById("play-btn");
        const iconPlay = document.getElementById("icon-play");
        const iconPause = document.getElementById("icon-pause");
        const audio = document.getElementById("radio-audio") as HTMLAudioElement;
        const playerStatus = document.getElementById("player-status");
        const playerProgress = document.getElementById("player-progress");
        const spinDisc = document.getElementById("spin-disc");
        const alAirePing = document.getElementById("al-aire-ping");
        
        const showTitle = document.getElementById("show-title");
        
        const btnMute = document.getElementById("btn-mute");
        const iconVolUp = document.getElementById("icon-vol-up");
        const iconVolMute = document.getElementById("icon-vol-mute");
        
        const volumeSlider = document.getElementById("volume-slider") as HTMLInputElement;
        const volumeSliderMobile = document.getElementById("volume-slider-mobile") as HTMLInputElement;
        
        let isPlaying = false;
        let lastVolume = 1;
        
        // --- Lógica de Horarios ---
        const updateShowTitle = () => {
            const now = new Date();
            // Aseguramos hora de Caracas
            const caracasTimeStr = now.toLocaleString("en-US", { timeZone: "America/Caracas" });
            const caracasNow = new Date(caracasTimeStr);
            
            const dayOfWeek = caracasNow.getDay();
            const currentHour = caracasNow.getHours();
            
            const isWeekend = dayOfWeek === SUNDAY_DAY_INDEX || dayOfWeek === SATURDAY_DAY_INDEX;
            const isShowTime = currentHour >= SHOW_START_HOUR && currentHour < SHOW_END_HOUR;
            const isFanaticosShow = isWeekend && isShowTime;
            
            if (showTitle) {
                if (isFanaticosShow) {
                    showTitle.textContent = "Misión 94.3 FM - Fanáticos de la Música";
                    showTitle.classList.add("text-brand-primary");
                    showTitle.classList.remove("text-gray-400");
                } else {
                    showTitle.textContent = "Misión 94.3 FM - Otro Programa";
                    showTitle.classList.remove("text-brand-primary");
                    showTitle.classList.add("text-gray-400");
                }
            }
        };

        // Actualizar el título inicialmente y revisarlo cada minuto
        updateShowTitle();
        setInterval(updateShowTitle, 60000); 

        // --- Lógica Play/Pause ---
        playBtn?.addEventListener("click", () => {
            if (isPlaying) {
                audio?.pause();
                iconPlay?.classList.remove("hidden");
                iconPause?.classList.add("hidden");
                if (playerStatus) playerStatus.textContent = "Transmisión pausada.";
                playerProgress?.classList.remove("animate-[pulse_2s_ease-in-out_infinite]");
                playerProgress?.classList.replace("scale-x-100", "scale-x-0");
                spinDisc?.classList.replace("animate-[spin_4s_linear_infinite]", "animate-none");
                alAirePing?.classList.add("hidden");
                alAirePing?.classList.remove("animate-ping");
                isPlaying = false;
            } else {
                audio?.play().catch(() => {
                    if (playerStatus) playerStatus.textContent = "Stream no disponible en este momento.";
                });
                iconPlay?.classList.add("hidden");
                iconPause?.classList.remove("hidden");
                if (playerStatus) playerStatus.textContent = "Conectado al stream de Misión 94.3 FM...";
                playerProgress?.classList.replace("scale-x-0", "scale-x-100");
                playerProgress?.classList.add("animate-[pulse_2s_ease-in-out_infinite]");
                spinDisc?.classList.replace("animate-none", "animate-[spin_4s_linear_infinite]");
                alAirePing?.classList.remove("hidden");
                alAirePing?.classList.add("animate-ping");
                isPlaying = true;
            }
        });

        // --- Lógica Control de Volumen ---
        const updateVolumeUI = (vol: number) => {
            if(audio) audio.volume = vol;
            if(volumeSlider) volumeSlider.value = vol.toString();
            if(volumeSliderMobile) volumeSliderMobile.value = vol.toString();
            
            if (vol === 0) {
                iconVolUp?.classList.add("hidden");
                iconVolMute?.classList.remove("hidden");
            } else {
                iconVolUp?.classList.remove("hidden");
                iconVolMute?.classList.add("hidden");
            }
        };

        volumeSlider?.addEventListener("input", (e) => {
            const vol = parseFloat((e.target as HTMLInputElement).value);
            lastVolume = vol > 0 ? vol : 0.5; // Guardamos el last volume por si desmutea
            updateVolumeUI(vol);
        });

        volumeSliderMobile?.addEventListener("input", (e) => {
            const vol = parseFloat((e.target as HTMLInputElement).value);
            lastVolume = vol > 0 ? vol : 0.5;
            updateVolumeUI(vol);
        });

        btnMute?.addEventListener("click", () => {
            if (audio?.volume! > 0) {
                updateVolumeUI(0); // Mutear
            } else {
                updateVolumeUI(lastVolume); // Desmutear
            }
        });
    });
</script>
