---
import { advertisers } from '../../../data/advertisers';
import AdvertiserCard from '../ui/AdvertiserCard.astro';
---

<section id="anunciantes" class="py-24 bg-white relative overflow-hidden">
    <!-- Decoración de fondo -->
    <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-brand-primary/30 to-transparent"></div>
    <div class="absolute -left-20 top-20 w-72 h-72 bg-brand-accent-yellow/5 rounded-full blur-3xl"></div>
    
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-4xl md:text-5xl font-extrabold text-brand-dark mb-4">Nuestros <span class="text-brand-primary">Anunciantes</span></h2>
            <p class="text-lg text-gray-600">
                Gracias a estas increíbles empresas y profesionales, Fanáticos de la Música sigue al aire llevando alegría a tus días. ¡Apoya el comercio local!
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            {advertisers.map((ad) => (
                <AdvertiserCard advertiser={ad} />
            ))}
        </div>
        
    </div>
</section>
