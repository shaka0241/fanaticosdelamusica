---
import Button from '../ui/Button.astro';
---

<section id="inicio" class="relative bg-brand-dark overflow-hidden min-h-[90vh] flex items-center justify-center pt-20 pb-32">
    <!-- Overlay gradiente cálido -->
    <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/20 to-brand-dark z-0"></div>
    
    <!-- Decoración geométrica -->
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-brand-primary/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-brand-secondary/10 blur-3xl"></div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-4xl mx-auto flex flex-col items-center">
            
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-accent-red/10 border border-brand-accent-red/20 mb-8 animate-pulse">
                <span class="flex h-2 w-2 relative">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent-red opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent-red"></span>
                </span>
                <span class="text-white text-sm font-medium tracking-wide">¡ENTRETENIENDO Y ALEGRANDO!</span>
            </div>

            <h1 class="text-5xl md:text-7xl font-extrabold text-white mb-6 tracking-tight leading-tight">
                Los mejores recuerdos de tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-primary to-brand-accent-yellow">juventud</span>
            </h1>
            
            <p class="mt-4 text-xl md:text-2xl text-gray-300 mb-10 max-w-2xl leading-relaxed">
                El programa de radio con la música de Los Blanco, Súper Combo Los Tropicales, La Billo's, Los Melódicos y más. ¡Jocosidad y buena vibra al aire!
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center w-full max-w-md mx-auto">
                <!-- Este botón podría interactuar con el reproductor de radio más abajo -->
                <Button variant="secondary" size="lg" class="w-full max-w-[280px] sm:max-w-none sm:w-auto h-14" href="#reproductor">
                    <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Escuchar en Vivo
                </Button>
                
                <Button variant="outline" size="lg" class="w-full max-w-[280px] sm:max-w-none sm:w-auto h-14" href="#nosotros">
                    Conocer Más
                </Button>
            </div>
        </div>
    </div>
    
    <!-- Onda separadora inferior -->
    <div class="absolute bottom-0 left-0 right-0 overflow-hidden text-brand-light transform translate-y-1">
        <svg viewBox="0 0 1200 120" preserveAspectRatio="none" class="w-full h-16 md:h-24 fill-current">
            <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C59.71,118,130.41,123.63,197.6,112.55,241.25,105.3,283.47,81.36,321.39,56.44Z"></path>
        </svg>
    </div>
</section>
